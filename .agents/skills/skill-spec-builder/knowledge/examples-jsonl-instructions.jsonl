{"_skill": "vercel-preview-smoke-test", "_note": "Calibration anchor — every line below corresponds 1:1 to an execution_steps item in examples-skill-yml.md."}
{"step_id": 1, "action_directive": "Read PR number", "operational_parameters": {"source": "user_request"}, "validation_criteria": ["PR number parsed as a positive integer."]}
{"step_id": 2, "action_directive": "Resolve preview URL", "operational_parameters": {"pr_number": "<from_step_1>", "vercel_token": "${VERCEL_TOKEN}"}, "validation_criteria": ["URL resolved via Vercel API.", "URL matches the pattern https://*.vercel.app."], "depends_on": [1]}
{"step_id": 3, "action_directive": "Probe URL", "operational_parameters": {"url": "<from_step_2>", "method": "HEAD", "timeout_seconds": 10}, "validation_criteria": ["HTTP status is in 2xx.", "Response received within 10 seconds."], "depends_on": [2]}
{"step_id": 4, "action_directive": "Probe URL", "operational_parameters": {"base_url": "<from_step_2>", "paths": ["/", "/login", "/checkout"], "method": "GET", "timeout_seconds": 10}, "validation_criteria": ["All three probes returned a status code.", "Latency captured for each probe."], "depends_on": [2]}
{"step_id": 5, "action_directive": "Retry failed probes", "operational_parameters": {"retry_threshold": "5xx", "max_retries": 1, "backoff_seconds": 5}, "validation_criteria": ["Each 5xx probe attempted exactly once more.", "4xx probes were not retried."], "depends_on": [4]}
{"step_id": 6, "action_directive": "Format output", "operational_parameters": {"format": "markdown_table", "columns": ["path", "status", "latency_ms", "attempt"]}, "validation_criteria": ["Output is a single markdown table.", "Every probe has exactly one row per attempt."], "depends_on": [5]}
{"step_id": 7, "action_directive": "Return to user", "operational_parameters": {"destination": "chat"}, "validation_criteria": ["Markdown table delivered in-chat."], "depends_on": [6]}
{"_skill": "incident-response-runbook", "_note": "Second calibration anchor — Slack draft is never auto-posted."}
{"step_id": 1, "action_directive": "Read alert ID", "operational_parameters": {"source": "user_message"}, "validation_criteria": ["Alert ID extracted as a string."]}
{"step_id": 2, "action_directive": "Fetch alert payload", "operational_parameters": {"alert_id": "<from_step_1>", "pagerduty_token": "${PAGERDUTY_TOKEN}"}, "validation_criteria": ["PagerDuty API returned 200.", "Payload contains alert title and severity."], "depends_on": [1]}
{"step_id": 3, "action_directive": "Resolve affected service", "operational_parameters": {"alert_payload": "<from_step_2>"}, "validation_criteria": ["Service name extracted from alert metadata."], "depends_on": [2]}
{"step_id": 4, "action_directive": "Fetch recent deploys", "operational_parameters": {"service": "<from_step_3>", "count": 5, "github_token": "${GITHUB_TOKEN}"}, "validation_criteria": ["GitHub Deployments API returned 200.", "At least one deploy entry returned or empty array if service has no deploys."], "depends_on": [3]}
{"step_id": 5, "action_directive": "Compile summary", "operational_parameters": {"alert": "<from_step_2>", "service": "<from_step_3>", "deploys": "<from_step_4>"}, "validation_criteria": ["Summary contains alert title, severity, service name, deploy timeline."], "depends_on": [2, 3, 4]}
{"step_id": 6, "action_directive": "Draft Slack post", "operational_parameters": {"channel": "#incident-${service}", "summary": "<from_step_5>", "status": "investigating"}, "validation_criteria": ["Draft contains the summary block and an investigating status line.", "Draft is not transmitted to Slack."], "depends_on": [5]}
{"step_id": 7, "action_directive": "Return to user", "operational_parameters": {"destination": "chat", "payload": ["summary", "draft_slack_post"]}, "validation_criteria": ["Both summary and draft delivered in-chat for human approval."], "depends_on": [5, 6]}
{"_skill": "internal-package-publisher", "_note": "Third calibration anchor — abort-on-fail at every gate; no partial publishes."}
{"step_id": 1, "action_directive": "Read release version", "operational_parameters": {"source": "merged_pr_title"}, "validation_criteria": ["Version parsed as valid semver."]}
{"step_id": 2, "action_directive": "Validate clean working tree", "operational_parameters": {"command": "git status --porcelain"}, "validation_criteria": ["Command output is empty."]}
{"step_id": 3, "action_directive": "Validate not prerelease", "operational_parameters": {"version": "<from_step_1>"}, "validation_criteria": ["Version contains no -alpha, -beta, or -rc suffix."], "depends_on": [1]}
{"step_id": 4, "action_directive": "Run lint", "operational_parameters": {"command": "pnpm lint"}, "validation_criteria": ["Exit code is 0."]}
{"step_id": 5, "action_directive": "Run typecheck", "operational_parameters": {"command": "pnpm typecheck"}, "validation_criteria": ["Exit code is 0."]}
{"step_id": 6, "action_directive": "Run tests", "operational_parameters": {"command": "pnpm test"}, "validation_criteria": ["Exit code is 0."]}
{"step_id": 7, "action_directive": "Publish package", "operational_parameters": {"command": "pnpm publish", "registry_token": "${NPM_REGISTRY_TOKEN}"}, "validation_criteria": ["Publish completed with exit code 0.", "Registry tarball URL returned."], "depends_on": [2, 3, 4, 5, 6]}
{"step_id": 8, "action_directive": "Return publish summary", "operational_parameters": {"version": "<from_step_1>", "registry_url": "<from_step_7>"}, "validation_criteria": ["Version and registry URL delivered in-chat."], "depends_on": [1, 7]}
